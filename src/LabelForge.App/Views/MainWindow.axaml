<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LabelForge.App.ViewModels"
        xmlns:views="using:LabelForge.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="LabelForge.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1200" Height="760"
        Title="LabelForge">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <TabControl Name="MainTabs" Padding="0" Margin="0,4,0,0">
        <TabItem Header="Designer">
            <views:DesignerView DataContext="{Binding Designer}" />
        </TabItem>
        <TabItem Header="ZPL Viewer">
            <views:ViewerView DataContext="{Binding Viewer}" />
        </TabItem>
    </TabControl>

</Window>
