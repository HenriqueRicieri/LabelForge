<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LabelForge.App.ViewModels"
        xmlns:controls="using:LabelForge.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="720"
        x:Class="LabelForge.App.Views.DesignerView"
        x:DataType="vm:DesignerViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.propLabel">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <!-- Square icon buttons in the left tool bar -->
        <Style Selector="Button.tool">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.tool PathIcon">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
        </Style>
        <Style Selector="Button.tool.armed">
            <Setter Property="Background" Value="#2E2563EB" />
            <Setter Property="BorderBrush" Value="#2563EB" />
        </Style>
    </UserControl.Styles>

    <UserControl.DataTemplates>

        <DataTemplate DataType="vm:TextPropertiesViewModel">
            <StackPanel Spacing="4">
                <TextBlock Classes="propLabel" Text="Text" />
                <TextBox Text="{Binding Text}" />
                <TextBlock Classes="propLabel" Text="Font height (dots)" />
                <NumericUpDown Value="{Binding FontHeight}" Minimum="6" Maximum="600"
                               Increment="2" FormatString="0" />
                <TextBlock Classes="propLabel" Text="Font width (dots, 0 = auto)" />
                <NumericUpDown Value="{Binding FontWidth}" Minimum="0" Maximum="600"
                               Increment="2" FormatString="0" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="vm:BarcodePropertiesViewModel">
            <StackPanel Spacing="4">
                <TextBlock Classes="propLabel" Text="Data" />
                <TextBox Text="{Binding Data}" />
                <TextBlock Text="{Binding Warning}" IsVisible="{Binding HasWarning}"
                           Foreground="#D97706" TextWrapping="Wrap" FontSize="12" Margin="0,2,0,0" />
                <TextBlock Classes="propLabel" Text="Symbology" />
                <ComboBox ItemsSource="{Binding Symbologies}"
                          SelectedItem="{Binding Symbology}"
                          HorizontalAlignment="Stretch" />
                <TextBlock Classes="propLabel" Text="Height (dots)" />
                <NumericUpDown Value="{Binding Height}" Minimum="10" Maximum="2000"
                               Increment="10" FormatString="0" />
                <TextBlock Classes="propLabel" Text="Module width (dots, 1-10)" />
                <NumericUpDown Value="{Binding ModuleWidth}" Minimum="1" Maximum="10"
                               Increment="1" FormatString="0" />
                <StackPanel IsVisible="{Binding IsCode39}" Spacing="4">
                    <TextBlock Classes="propLabel" Text="Wide bar ratio (Code 39)" />
                    <NumericUpDown Value="{Binding Ratio}" Minimum="2" Maximum="3"
                                   Increment="0.1" FormatString="0.0" />
                </StackPanel>
                <CheckBox Content="Print interpretation line"
                          IsChecked="{Binding Interpretation}" Margin="0,4,0,0" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="vm:QrPropertiesViewModel">
            <StackPanel Spacing="4">
                <TextBlock Classes="propLabel" Text="Data" />
                <TextBox Text="{Binding Data}" />
                <TextBlock Classes="propLabel" Text="Magnification (1-10)" />
                <NumericUpDown Value="{Binding Magnification}" Minimum="1" Maximum="10"
                               Increment="1" FormatString="0" />
                <TextBlock Classes="propLabel" Text="Error correction" />
                <ComboBox ItemsSource="{Binding ErrorCorrections}"
                          SelectedItem="{Binding ErrorCorrection}"
                          HorizontalAlignment="Stretch" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="vm:LinePropertiesViewModel">
            <StackPanel Spacing="4">
                <TextBlock Classes="propLabel" Text="Length (dots)" />
                <NumericUpDown Value="{Binding Length}" Minimum="1" Maximum="5000"
                               Increment="10" FormatString="0" />
                <TextBlock Classes="propLabel" Text="Thickness (dots)" />
                <NumericUpDown Value="{Binding Thickness}" Minimum="1" Maximum="200"
                               Increment="1" FormatString="0" />
                <CheckBox Content="Vertical" IsChecked="{Binding IsVertical}" Margin="0,4,0,0" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="vm:BoxPropertiesViewModel">
            <StackPanel Spacing="4">
                <TextBlock Classes="propLabel" Text="Width (dots)" />
                <NumericUpDown Value="{Binding BoxWidth}" Minimum="4" Maximum="5000"
                               Increment="10" FormatString="0" />
                <TextBlock Classes="propLabel" Text="Height (dots)" />
                <NumericUpDown Value="{Binding BoxHeight}" Minimum="4" Maximum="5000"
                               Increment="10" FormatString="0" />
                <TextBlock Classes="propLabel" Text="Border thickness (dots)" />
                <NumericUpDown Value="{Binding Thickness}" Minimum="1" Maximum="200"
                               Increment="1" FormatString="0" />
            </StackPanel>
        </DataTemplate>

    </UserControl.DataTemplates>

    <DockPanel>

        <!-- Menu bar -->
        <Border DockPanel.Dock="Top" Padding="4,0" Background="{DynamicResource AppBarBackground}">
            <DockPanel>
                <Menu DockPanel.Dock="Left" VerticalAlignment="Center">
                    <MenuItem Header="_File">
                        <MenuItem Header="_New" Command="{Binding NewDocumentCommand}" InputGesture="Ctrl+N" />
                        <MenuItem Header="New from _Sample" Command="{Binding LoadSampleCommand}" />
                        <MenuItem Header="_Open..." Click="OnOpenFile" InputGesture="Ctrl+O" />
                        <Separator />
                        <MenuItem Header="_Save" Click="OnSaveFile" InputGesture="Ctrl+S" />
                        <MenuItem Header="Save _As..." Click="OnSaveFileAs" />
                        <Separator />
                        <MenuItem Header="Export _ZPL..." Click="OnExportZpl" />
                        <MenuItem Header="Export _PNG..." Click="OnExportPng" />
                        <MenuItem Header="Export P_DF..." Click="OnExportPdf" />
                    </MenuItem>
                    <MenuItem Header="_Edit">
                        <MenuItem Header="_Undo" Command="{Binding UndoCommand}" InputGesture="Ctrl+Z" />
                        <MenuItem Header="_Redo" Command="{Binding RedoCommand}" InputGesture="Ctrl+Y" />
                        <Separator />
                        <MenuItem Header="_Copy" Command="{Binding CopyCommand}" InputGesture="Ctrl+C" />
                        <MenuItem Header="_Paste" Command="{Binding PasteCommand}" InputGesture="Ctrl+V" />
                        <MenuItem Header="D_uplicate" Command="{Binding DuplicateCommand}" InputGesture="Ctrl+D" />
                        <Separator />
                        <MenuItem Header="Bring to _Front" Command="{Binding BringToFrontCommand}" />
                        <MenuItem Header="Send to _Back" Command="{Binding SendToBackCommand}" />
                        <Separator />
                        <MenuItem Header="A_lign">
                            <MenuItem Header="_Left" Command="{Binding AlignLeftCommand}" />
                            <MenuItem Header="_Center" Command="{Binding AlignCenterHorizontalCommand}" />
                            <MenuItem Header="_Right" Command="{Binding AlignRightCommand}" />
                            <Separator />
                            <MenuItem Header="_Top" Command="{Binding AlignTopCommand}" />
                            <MenuItem Header="_Middle" Command="{Binding AlignMiddleCommand}" />
                            <MenuItem Header="_Bottom" Command="{Binding AlignBottomCommand}" />
                            <Separator />
                            <MenuItem Header="Distribute _Horizontally" Command="{Binding DistributeHorizontalCommand}" />
                            <MenuItem Header="Distribute _Vertically" Command="{Binding DistributeVerticalCommand}" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="_Delete" Command="{Binding DeleteSelectedCommand}" InputGesture="Delete" />
                    </MenuItem>
                    <MenuItem Header="_View">
                        <MenuItem Header="Theme: _System" Click="OnThemeSystem" />
                        <MenuItem Header="Theme: _Light" Click="OnThemeLight" />
                        <MenuItem Header="Theme: _Dark" Click="OnThemeDark" />
                    </MenuItem>
                    <MenuItem Header="_Insert">
                        <MenuItem Header="_Text" Command="{Binding AddTextCommand}" />
                        <MenuItem Header="_Box" Command="{Binding AddBoxCommand}" />
                        <MenuItem Header="_Line" Command="{Binding AddLineCommand}" />
                        <MenuItem Header="Ba_rcode" Command="{Binding AddBarcodeCommand}" />
                        <MenuItem Header="_QR Code" Command="{Binding AddQrCommand}" />
                    </MenuItem>
                </Menu>
                <Button DockPanel.Dock="Right" Content="Print..." Margin="4,4">
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <StackPanel Spacing="6" Width="240">
                                <TextBlock Text="Network printer (TCP 9100)" FontWeight="SemiBold" FontSize="12" />
                                <TextBox Text="{Binding PrinterHost}" PlaceholderText="192.168.0.50" />
                                <TextBlock Text="Port" FontSize="12" Opacity="0.8" />
                                <NumericUpDown Value="{Binding PrinterPort}" Minimum="1" Maximum="65535"
                                               Increment="1" FormatString="0" />
                                <Button Content="Send via network" Command="{Binding PrintCommand}"
                                        HorizontalAlignment="Stretch" />
                                <Rectangle Height="1" Fill="{DynamicResource AppSeparator}" Margin="0,6" />
                                <TextBlock Text="Windows printer (USB)" FontWeight="SemiBold" FontSize="12" />
                                <ComboBox ItemsSource="{Binding WindowsPrinters}"
                                          SelectedItem="{Binding SelectedWindowsPrinter}"
                                          HorizontalAlignment="Stretch"
                                          PlaceholderText="Pick an installed printer" />
                                <Button Content="Send via Windows spooler" Command="{Binding PrintWindowsCommand}"
                                        HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <TextBlock Text="{Binding CurrentFilePath}" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Margin="12,0"
                           Opacity="0.5" FontSize="12" />
            </DockPanel>
        </Border>

        <!-- Label setup -->
        <Border DockPanel.Dock="Top" Padding="10,8" Background="{DynamicResource AppToolbarBackground}">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Width (mm)" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding WidthMm}" Minimum="5" Maximum="600"
                               Increment="1" FormatString="0.#" Width="110" />
                <TextBlock Text="Height (mm)" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding HeightMm}" Minimum="5" Maximum="1000"
                               Increment="1" FormatString="0.#" Width="110" />
                <TextBlock Text="Density" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Densities}"
                          SelectedItem="{Binding SelectedDensity}" Width="100" />
                <Rectangle Width="1" Height="22" Fill="{DynamicResource AppSeparator}" />
                <TextBlock Text="Printer" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Printers}"
                          SelectedItem="{Binding SelectedPrinter}" MinWidth="160"
                          ToolTip.Tip="Selecting a printer adopts its density and validates the label against the print head" />
                <TextBlock Text="{Binding PrinterWarning}" VerticalAlignment="Center"
                           Foreground="#D97706" FontSize="12" FontWeight="SemiBold"
                           TextWrapping="Wrap" MaxWidth="300" />
                <TextBlock Text="{Binding ValidationWarning}" VerticalAlignment="Center"
                           IsVisible="{Binding ValidationWarning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Foreground="#D97706" FontSize="12" FontWeight="SemiBold"
                           TextWrapping="Wrap" MaxWidth="300"
                           ToolTip.Tip="{Binding ValidationWarning}" />
                <TextBlock Text="{Binding PlacementWarning}" VerticalAlignment="Center"
                           IsVisible="{Binding PlacementWarning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Foreground="#D97706" FontSize="12" FontWeight="SemiBold"
                           TextWrapping="Wrap" MaxWidth="340"
                           ToolTip.Tip="{Binding PlacementWarning}" />
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Opacity="0.6" />
            </StackPanel>
        </Border>

        <!-- Properties panel -->
        <Border DockPanel.Dock="Right" Width="260" Background="{DynamicResource AppPanelBackground}" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">
                    <TextBlock Text="Properties" FontWeight="SemiBold" />

                    <TextBlock Text="Nothing selected. Click an element on the canvas. Drag on empty space to select several; Ctrl+click adds or removes."
                               IsVisible="{Binding !HasSelection}"
                               TextWrapping="Wrap" Opacity="0.6" FontSize="12" />

                    <TextBlock Text="{Binding SelectionCount, StringFormat='{}{0} elements selected. Drag to move them together; Delete removes all; copy and z-order apply to the whole group.'}"
                               IsVisible="{Binding HasMultiSelection}"
                               TextWrapping="Wrap" Opacity="0.7" FontSize="12" />

                    <StackPanel IsVisible="{Binding IsSingleSelection}" Spacing="4">
                        <TextBlock Text="{Binding SelectionProperties.TypeName, FallbackValue=''}"
                                   FontWeight="SemiBold" Opacity="0.8" />
                        <CheckBox Content="Positions in mm" FontSize="12" Margin="0,2,0,0"
                                  IsChecked="{Binding SelectionProperties.UseMm, FallbackValue=false}"
                                  ToolTip.Tip="Type X and Y in millimeters; the label model keeps dots" />
                        <TextBlock Classes="propLabel"
                                   Text="{Binding SelectionProperties.UnitSuffix, StringFormat='X ({0})', FallbackValue='X (dots)'}" />
                        <NumericUpDown Value="{Binding SelectionProperties.X, FallbackValue=0}"
                                       Increment="1"
                                       FormatString="{Binding SelectionProperties.PositionFormat, FallbackValue=0}"
                                       Minimum="-9999" />
                        <TextBlock Classes="propLabel"
                                   Text="{Binding SelectionProperties.UnitSuffix, StringFormat='Y ({0})', FallbackValue='Y (dots)'}" />
                        <NumericUpDown Value="{Binding SelectionProperties.Y, FallbackValue=0}"
                                       Increment="1"
                                       FormatString="{Binding SelectionProperties.PositionFormat, FallbackValue=0}"
                                       Minimum="-9999" />
                        <TextBlock Classes="propLabel" Text="Rotation" />
                        <ComboBox ItemsSource="{Binding SelectionProperties.Orientations, FallbackValue={x:Null}}"
                                  SelectedItem="{Binding SelectionProperties.SelectedOrientation, FallbackValue={x:Null}}"
                                  HorizontalAlignment="Stretch" />

                        <Rectangle Height="1" Fill="{DynamicResource AppSeparator}" Margin="0,8" />

                        <!-- Type-specific editor, picked by DataTemplate -->
                        <ContentControl Content="{Binding SelectionProperties}" />

                        <TextBlock Text="Drag to move. Corner handles resize proportionally; edge handles resize one axis (barcodes snap to module steps). The round handle rotates; ZPL printers only support 0/90/180/270. Arrow keys nudge by 1 dot (Shift = 10). Delete removes. Ctrl+Z / Ctrl+Y undo and redo."
                                   TextWrapping="Wrap" Opacity="0.5" FontSize="11" Margin="0,8,0,0" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Generated ZPL -->
        <Expander DockPanel.Dock="Bottom" Header="Generated ZPL" IsExpanded="False">
            <TextBox Text="{Binding GeneratedZpl}" IsReadOnly="True"
                     FontFamily="Consolas,Menlo,Monospace" FontSize="12"
                     Height="140" TextWrapping="NoWrap" />
        </Expander>

        <!-- Tool bar: insert tools, then alignment, as square icon buttons -->
        <Border DockPanel.Dock="Left" Background="{DynamicResource AppToolbarBackground}" Padding="5,8">
            <StackPanel Spacing="3">
                <Button Classes="tool" Classes.armed="{Binding IsTextArmed}"
                        Command="{Binding AddTextCommand}" ToolTip.Tip="Add text">
                    <PathIcon Data="M2,2 L14,2 L14,5 L9.4,5 L9.4,14 L6.6,14 L6.6,5 L2,5 Z" />
                </Button>
                <Button Classes="tool" Classes.armed="{Binding IsBoxArmed}"
                        Command="{Binding AddBoxCommand}" ToolTip.Tip="Add box">
                    <PathIcon Data="M2,3 L14,3 L14,13 L2,13 Z M3.8,4.8 L12.2,4.8 L12.2,11.2 L3.8,11.2 Z" />
                </Button>
                <Button Classes="tool" Classes.armed="{Binding IsLineArmed}"
                        Command="{Binding AddLineCommand}" ToolTip.Tip="Add line">
                    <PathIcon Data="M2.2,12.4 L12.4,2.2 L13.8,3.6 L3.6,13.8 Z" />
                </Button>
                <Button Classes="tool" Classes.armed="{Binding IsBarcodeArmed}"
                        Command="{Binding AddBarcodeCommand}" ToolTip.Tip="Add barcode">
                    <PathIcon Data="M2,3 L3.4,3 L3.4,13 L2,13 Z M4.6,3 L5.6,3 L5.6,13 L4.6,13 Z M7,3 L9.4,3 L9.4,13 L7,13 Z M10.6,3 L11.6,3 L11.6,13 L10.6,13 Z M12.8,3 L14,3 L14,13 L12.8,13 Z" />
                </Button>
                <Button Classes="tool" Classes.armed="{Binding IsQrArmed}"
                        Command="{Binding AddQrCommand}" ToolTip.Tip="Add QR code">
                    <PathIcon Data="M2,2 L7,2 L7,7 L2,7 Z M3.6,3.6 L5.4,3.6 L5.4,5.4 L3.6,5.4 Z M9,2 L14,2 L14,7 L9,7 Z M10.6,3.6 L12.4,3.6 L12.4,5.4 L10.6,5.4 Z M2,9 L7,9 L7,14 L2,14 Z M3.6,10.6 L5.4,10.6 L5.4,12.4 L3.6,12.4 Z M9,9 L11,9 L11,11 L9,11 Z M12,9 L14,9 L14,11 L12,11 Z M9,12 L11,12 L11,14 L9,14 Z M12,12 L14,12 L14,14 L12,14 Z" />
                </Button>

                <Rectangle Height="1" Fill="{DynamicResource AppSeparator}" Margin="2,5" />

                <Button Classes="tool" Command="{Binding AlignLeftCommand}"
                        ToolTip.Tip="Align left (single element: to the label)">
                    <PathIcon Data="M2,2 L3.6,2 L3.6,14 L2,14 Z M5.2,3.6 L14,3.6 L14,6.4 L5.2,6.4 Z M5.2,9.6 L10.5,9.6 L10.5,12.4 L5.2,12.4 Z" />
                </Button>
                <Button Classes="tool" Command="{Binding AlignCenterHorizontalCommand}"
                        ToolTip.Tip="Align horizontal centers (single element: center on label)">
                    <PathIcon Data="F1 M7.2,2 L8.8,2 L8.8,14 L7.2,14 Z M3,3.6 L13,3.6 L13,6.4 L3,6.4 Z M5,9.6 L11,9.6 L11,12.4 L5,12.4 Z" />
                </Button>
                <Button Classes="tool" Command="{Binding AlignRightCommand}"
                        ToolTip.Tip="Align right (single element: to the label)">
                    <PathIcon Data="M12.4,2 L14,2 L14,14 L12.4,14 Z M2,3.6 L10.8,3.6 L10.8,6.4 L2,6.4 Z M5.5,9.6 L10.8,9.6 L10.8,12.4 L5.5,12.4 Z" />
                </Button>
                <Button Classes="tool" Command="{Binding AlignTopCommand}"
                        ToolTip.Tip="Align top (single element: to the label)">
                    <PathIcon Data="M2,2 L14,2 L14,3.6 L2,3.6 Z M3.6,5.2 L6.4,5.2 L6.4,14 L3.6,14 Z M9.6,5.2 L12.4,5.2 L12.4,10.5 L9.6,10.5 Z" />
                </Button>
                <Button Classes="tool" Command="{Binding AlignMiddleCommand}"
                        ToolTip.Tip="Align vertical centers (single element: center on label)">
                    <PathIcon Data="F1 M2,7.2 L14,7.2 L14,8.8 L2,8.8 Z M3.6,3 L6.4,3 L6.4,13 L3.6,13 Z M9.6,5 L12.4,5 L12.4,11 L9.6,11 Z" />
                </Button>
                <Button Classes="tool" Command="{Binding AlignBottomCommand}"
                        ToolTip.Tip="Align bottom (single element: to the label)">
                    <PathIcon Data="M2,12.4 L14,12.4 L14,14 L2,14 Z M3.6,2 L6.4,2 L6.4,10.8 L3.6,10.8 Z M9.6,5.5 L12.4,5.5 L12.4,10.8 L9.6,10.8 Z" />
                </Button>

                <Rectangle Height="1" Fill="{DynamicResource AppSeparator}" Margin="2,5" />

                <Button Classes="tool" Command="{Binding DistributeHorizontalCommand}"
                        ToolTip.Tip="Distribute horizontally (needs 3+ elements)">
                    <PathIcon Data="M2,2 L3.6,2 L3.6,14 L2,14 Z M12.4,2 L14,2 L14,14 L12.4,14 Z M6.6,4.5 L9.4,4.5 L9.4,11.5 L6.6,11.5 Z" />
                </Button>
                <Button Classes="tool" Command="{Binding DistributeVerticalCommand}"
                        ToolTip.Tip="Distribute vertically (needs 3+ elements)">
                    <PathIcon Data="M2,2 L14,2 L14,3.6 L2,3.6 Z M2,12.4 L14,12.4 L14,14 L2,14 Z M4.5,6.6 L11.5,6.6 L11.5,9.4 L4.5,9.4 Z" />
                </Button>
            </StackPanel>
        </Border>

        <!-- Canvas with mm rulers (drawn by the control) and scrollbars -->
        <Grid RowDefinitions="*,Auto" ColumnDefinitions="*,Auto">
            <controls:DesignerCanvas Name="Canvas"
                                     Underlay="{Binding Underlay}"
                                     UnderlayMarginDots="{Binding UnderlayMarginDots}"
                                     Document="{Binding Document}"
                                     Selection="{Binding Selection}"
                                     IsPlacing="{Binding IsPlacing}" />
            <ScrollBar Name="CanvasVScroll" Grid.Column="1" Orientation="Vertical"
                       AllowAutoHide="False" Visibility="Visible" />
            <ScrollBar Name="CanvasHScroll" Grid.Row="1" Orientation="Horizontal"
                       AllowAutoHide="False" Visibility="Visible" />

            <!-- Floating zoom control over the canvas corner -->
            <Border Grid.Row="0" Grid.Column="0"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,12,12"
                    Background="{DynamicResource AppPanelBackground}"
                    BorderBrush="{DynamicResource AppSeparator}" BorderThickness="1"
                    CornerRadius="4" Padding="2">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Name="ZoomOutButton" Content="-" Padding="8,2" FontSize="12"
                            ToolTip.Tip="Zoom out (Ctrl+wheel)" />
                    <Button Name="ZoomLevelButton" Content="100%" MinWidth="58" Padding="6,2"
                            FontSize="12" HorizontalContentAlignment="Center"
                            ToolTip.Tip="Zoom presets; 100% = 1 dot per pixel">
                        <Button.Flyout>
                            <MenuFlyout Placement="Top">
                                <MenuItem Header="50%" Click="OnZoom50" />
                                <MenuItem Header="100%" Click="OnZoom100" />
                                <MenuItem Header="200%" Click="OnZoom200" />
                                <MenuItem Header="Fit label" Click="OnZoomFit" InputGesture="Ctrl+0" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button Name="ZoomInButton" Content="+" Padding="8,2" FontSize="12"
                            ToolTip.Tip="Zoom in (Ctrl+wheel)" />
                </StackPanel>
            </Border>
        </Grid>

    </DockPanel>

</UserControl>
